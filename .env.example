# BNET API credentials
CLIENT_ID=
CLIENT_SECRET=
# Blizzard API region and locale
# Example: eu, us, kr, tw
REGION=
# Example: en_US, es_ES, fr_FR
LOCALE=

# Guild information
GUILD_NAME=
GUILD_SLUG=

# Database configuration
POSTGRES_USER=fastapi
POSTGRES_PASSWORD=changeme
POSTGRES_DB=wowdb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Optional: set DATABASE_URL instead of individual fields
# DATABASE_URL=postgresql://fastapi:changeme@localhost:5432/wowdb

# JWT configuration
JWT_SECRET_KEY=super-secret-key
# Optional: override token lifetime (minutes)
# JWT_EXPIRE_MINUTES=60

# Instance data backend: yaml (default) reads from data/instances/ YAML files,
# db reads from the database (seed first with POST /api/admin/instances/seed)
INSTANCE_BACKEND=yaml

# Game mode: retail regenerates instance data on update
# For private servers use the expansion name (e.g. classic, tbc, wotlk, cataclysm)
GAME_MODE=retail

# GitHub repository used for update checks (override if you fork the repo)
GITHUB_REPO=GFerreiroS/wow-guild-api
