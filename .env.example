# BNET API credentials
CLIENT_ID=
CLIENT_SECRET=
# Blizzard API region and locale
# Example: eu, us, kr, tw
REGION=
# Example: en_US, es_ES, fr_FR
LOCALE=

# Guild information
GUILD_NAME=
GUILD_SLUG=

# Database configuration
POSTGRES_USER=fastapi
POSTGRES_PASSWORD=changeme
POSTGRES_DB=wowdb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Optional: set DATABASE_URL instead of individual fields
# DATABASE_URL=postgresql://fastapi:changeme@localhost:5432/wowdb

# JWT configuration
JWT_SECRET_KEY=replace-this-with-a-long-random-secret-here
# Optional: override token lifetime (minutes)
# JWT_EXPIRE_MINUTES=60


# GitHub repository used for update checks (override if you fork the repo)
GITHUB_REPO=GFerreiroS/wow-guild-api

# Battle.net OAuth2 redirect URI — must match exactly what's registered in your Blizzard app
# Local dev: http://localhost:8000/api/auth/bnet/callback
# Production: https://yourdomain.com/api/auth/bnet/callback
BNET_CALLBACK_URL=http://localhost:8000/api/auth/bnet/callback

# CORS: comma-separated list of allowed frontend origins
# Use * to allow all (development only — set your frontend URL in production)
# Example: https://myguild.com,https://www.myguild.com
ALLOWED_ORIGINS=*
